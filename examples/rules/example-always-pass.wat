;; =============================================================================
;; example-always-pass.wat
;;
;; 最もシンプルなルール例: 常に PASS (0) を返す
;;
;; ビルド方法:
;;   wat2wasm example-always-pass.wat -o example-always-pass.wasm
;;
;; 実行:
;;   kubectl detective rule --rule example-always-pass.wasm
;; =============================================================================

(module
  ;; ---------------------------------------------------------------
  ;; ホスト関数 (detective が提供する)
  ;; WASM側から呼び出してログやアラートを送信できる
  ;; ---------------------------------------------------------------
  (import "env" "host_log"    (func $host_log    (param i32 i32)))
  (import "env" "host_alert"  (func $host_alert  (param i32 i32)))

  ;; ---------------------------------------------------------------
  ;; メモリ: ホストが JSON データを書き込む領域
  ;; 必ず "memory" としてエクスポートすること
  ;; ---------------------------------------------------------------
  (memory (export "memory") 1)

  ;; ---------------------------------------------------------------
  ;; データセクション: 文字列定数をメモリに配置
  ;; ルール名と説明は NUL終端の文字列へのポインタを返す
  ;; ---------------------------------------------------------------
  (data (i32.const 0)   "always-pass\00")            ;; offset 0..11
  (data (i32.const 12)  "Always returns PASS\00")    ;; offset 12..31

  ;; ---------------------------------------------------------------
  ;; rule_name: ルール名を返す
  ;;   戻り値: NUL終端文字列へのポインタ (i32)
  ;; ---------------------------------------------------------------
  (func (export "rule_name") (result i32)
    i32.const 0    ;; "always-pass" の先頭アドレス
  )

  ;; ---------------------------------------------------------------
  ;; rule_description: ルールの説明を返す
  ;;   戻り値: NUL終端文字列へのポインタ (i32)
  ;; ---------------------------------------------------------------
  (func (export "rule_description") (result i32)
    i32.const 12   ;; "Always returns PASS" の先頭アドレス
  )

  ;; ---------------------------------------------------------------
  ;; rule_init: ルール初期化
  ;;   戻り値: 0 = 成功, 以外 = エラー
  ;; ---------------------------------------------------------------
  (func (export "rule_init") (result i32)
    i32.const 0    ;; 成功
  )

  ;; ---------------------------------------------------------------
  ;; rule_evaluate: ルール評価 (メインロジック)
  ;;   パラメータ:
  ;;     $ctx_ptr: JSON データの先頭アドレス
  ;;     $ctx_len: JSON データのバイト長
  ;;   戻り値:
  ;;     0 = PASS (正常)
  ;;     1 = ALERT (アラート)
  ;;
  ;; JSON コンテキストの構造:
  ;;   {
  ;;     "throughputs": [...],
  ;;     "retransmissions": [...],
  ;;     "rtt": [...],
  ;;     "flows": [...]
  ;;   }
  ;; ---------------------------------------------------------------
  (func (export "rule_evaluate") (param $ctx_ptr i32) (param $ctx_len i32) (result i32)
    i32.const 0    ;; 常に PASS
  )
)
